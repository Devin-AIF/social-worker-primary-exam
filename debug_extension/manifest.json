{
  "manifest_version": 3,
  "name": "Scraper Monitor Ultra",
  "version": "1.2",
  "description": "加固型全域监控调试工具",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.xs507.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xs507.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
